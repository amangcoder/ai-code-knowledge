# ── Summarizer ────────────────────────────────────────────────────────────────
# Backend for generating file summaries: 'static' (default), 'ollama', 'anthropic'
SUMMARIZER_MODE=static

# Anthropic (required when SUMMARIZER_MODE=anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Ollama (used when SUMMARIZER_MODE=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:7b

# ── Embeddings ────────────────────────────────────────────────────────────────
# Embedding provider: 'huggingface' (default), 'local', 'codesage', 'ollama', 'openai', 'mock'
EMBEDDING_MODEL=huggingface

# HuggingFace embeddings
HF_MODEL=Salesforce/codesage-base
HF_API_TOKEN=
HF_DIMENSIONS=768

# OpenAI embeddings (required when EMBEDDING_MODEL=openai)
OPENAI_API_KEY=

# Local embedding server
LOCAL_EMBED_URL=http://localhost:8484
LOCAL_EMBED_DIMS=768

# Embedding concurrency (for Ollama provider)
EMBEDDING_CONCURRENCY=10

# ── Knowledge base ────────────────────────────────────────────────────────────
# Path to the .knowledge directory (relative or absolute)
KNOWLEDGE_ROOT=.knowledge

# Build richness level
KNOWLEDGE_RICHNESS=

# Max LRU cache entries for MCP tool queries
KNOWLEDGE_CACHE_MAX_ENTRIES=

# ── MCP Server ────────────────────────────────────────────────────────────────
# Workspace root for cumulative context tool
WORKSPACE_ROOT=

# Project root override — set this when the MCP server runs from a different
# directory than the indexed project (avoids incorrect path resolution)
PROJECT_ROOT=
